  "publicApiSurface": [
    "context - Core plugin APIs and lifecycle management",
    "park - Park management and financial operations",
    "map - Map manipulation and tile management",
    "network - Multiplayer server/client networking",
    "scenario - Scenario objectives and settings",
    "climate - Weather and climate control",
    "cheats - Cheat functionality",
    "ui - User interface and window management",
    "console - Logging and debugging",
    "date - In-game date and time",
    "objectManager - Game object loading and management",
    "profiler - Performance profiling tools"
